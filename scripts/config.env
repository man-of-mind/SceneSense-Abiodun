# Shared configuration for OAI helper scripts.
# Sourced by every script in this folder.

# --- Paths ---
export OAI_ROOT="/home/shr_aisvcs/workarea/carla_0_10_env/Carla-0.10.0-Linux-Shipping/PythonAPI/neu_collab/abiodun/OAI"
export OAI_CN_DIR="${OAI_ROOT}/oai-cn5g"
export OAI_RAN_BUILD="${OAI_ROOT}/openairinterface5g/cmake_targets/ran_build/build"
export OAI_RAN_CONF="${OAI_ROOT}/openairinterface5g/targets/PROJECTS/GENERIC-NR-5GC/CONF"
export OAI_T_TRACER_DIR="${OAI_ROOT}/openairinterface5g/common/utils/T/tracer"
export OAI_T_MESSAGES="${OAI_ROOT}/openairinterface5g/common/utils/T/T_messages.txt"

# --- Network endpoints (defaults match the standard OAI docker-compose) ---
export OAI_AMF_IP="192.168.70.132"
export OAI_SMF_IP="192.168.70.133"
export OAI_EXT_DN_IP="192.168.70.135"   # iperf server inside oai-ext-dn
export OAI_RX_IP="192.168.70.140"       # oai-perception-rx container (this folder)
export OAI_UE_IP="10.0.0.2"             # IP assigned to oaitun_ue1
export OAI_UE_IFACE="oaitun_ue1"
export OAI_UE2_IP="10.0.0.3"            # IP assigned to oaitun_ue2 in multi-UE mode
export OAI_UE2_IFACE="oaitun_ue2"

# --- Demo stream (sender <-> receiver container) ---
export UDP_PORT="65000"

# --- RAN/UE radio parameters (rfsim mode) ---
export GNB_CONF="gnb.sa.band78.fr1.106PRB.usrpb210.conf"
export UE_CONF="ue.conf"
export UE_RFSIM_SERVER="127.0.0.1"
export UE_PRB=106
export UE_NUMEROLOGY=1
export UE_BAND=78
export UE_DL_FREQ=3619200000
export UE_MULTI_CONF="ue.multi2.conf"
export UE_COUNT=2

# --- OAI T-tracer defaults ---
# Keep gNB and UE tracer ports separate when both softmodems run on this host.
export OAI_GNB_T_PORT=2021
export OAI_UE_T_PORT=2023
export OAI_T_STDOUT=2
